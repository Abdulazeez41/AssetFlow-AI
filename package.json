{
  "name": "assetflow-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "contracts:compile": "hardhat compile",
    "contracts:deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "contracts:deploy:hardhat": "hardhat run scripts/deploy.js --network hardhat",
    "seed": "node scripts/seed-data.js",
    "qa": "npm run seed && npm run typecheck && npm run contracts:compile && npm run build"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "ethers": "^6.15.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "3.0.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "hardhat": "2.22.17",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
